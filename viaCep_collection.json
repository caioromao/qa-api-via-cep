  "item": [
    {
      "name": "CEP válido sem hífen",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "const response = pm.response.json();\r",
              "\r",
              "pm.test(\"CEP correto\", function () {\r",
              "    pm.expect(response.cep).to.eql(\"74650-170\");\r",
              "});\r",
              "\r",
              "pm.test(\"Campos obrigatórios preenchidos\", function () {\r",
              "    pm.expect(response.logradouro).to.not.be.empty;\r",
              "    pm.expect(response.localidade).to.eql(\"Goiânia\");\r",
              "    pm.expect(response.uf).to.eql(\"GO\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
